{
  "version": 2,
  "builds": [
    {
      "src": "finance-app/public/index.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "outputDirectory": "finance-app/public/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "finance-app/public/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "finance-app/public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr"
  }
}
